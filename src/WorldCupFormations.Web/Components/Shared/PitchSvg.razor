@using WorldCupFormations.Services
@using Microsoft.AspNetCore.Components
@using System.Globalization
@using System.Web

<div class="pitch-container">
    <svg viewBox="0 0 680 1050" xmlns="http://www.w3.org/2000/svg" width="100%" style="overflow: visible;">

        <!-- Pitch surface -->
        <rect x="0" y="0" width="680" height="1050" fill="#2d7a3a" />

        <!-- Pitch stripes -->
        @for (int i = 0; i < 7; i++)
        {
            var yy = i * 150;
            <rect x="0" y="@yy" width="680" height="75" fill="#317d3e" opacity="0.4" />
        }

        <!-- Outer border -->
        <rect x="10" y="10" width="660" height="1030" fill="none" stroke="white" stroke-width="3" />

        <!-- Centre line -->
        <line x1="10" y1="525" x2="670" y2="525" stroke="white" stroke-width="2" />

        <!-- Centre circle -->
        <circle cx="340" cy="525" r="91" fill="none" stroke="white" stroke-width="2" />
        <circle cx="340" cy="525" r="5" fill="white" />

        <!-- Home penalty area -->
        <rect x="136" y="10" width="408" height="165" fill="none" stroke="white" stroke-width="2" />
        <rect x="240" y="10" width="200" height="55" fill="none" stroke="white" stroke-width="2" />
        <circle cx="340" cy="122" r="4" fill="white" />
        <rect x="265" y="0" width="150" height="15" fill="#888" stroke="white" stroke-width="1" />

        <!-- Away penalty area -->
        <rect x="136" y="875" width="408" height="165" fill="none" stroke="white" stroke-width="2" />
        <rect x="240" y="985" width="200" height="55" fill="none" stroke="white" stroke-width="2" />
        <circle cx="340" cy="928" r="4" fill="white" />
        <rect x="265" y="1035" width="150" height="15" fill="#888" stroke="white" stroke-width="1" />

        <!-- Corner arcs -->
        <path d="M 10 55 A 45 45 0 0 1 55 10" fill="none" stroke="white" stroke-width="2" />
        <path d="M 625 10 A 45 45 0 0 1 670 55" fill="none" stroke="white" stroke-width="2" />
        <path d="M 10 995 A 45 45 0 0 0 55 1040" fill="none" stroke="white" stroke-width="2" />
        <path d="M 625 1040 A 45 45 0 0 0 670 995" fill="none" stroke="white" stroke-width="2" />

        <!-- Formation labels (MarkupString to avoid Razor <text> conflict) -->
        @((MarkupString)RenderFormationLabels())

        <!-- Home players -->
        @{
            var homeFocused = FocusedSide is null || FocusedSide == TeamSide.Home;
            var homeOpacity = homeFocused ? "1" : "0.35";
            var homeFill    = homeFocused ? "#1a6fcb" : "#555";
        }
        @foreach (var (p, idx) in HomePlayers.Select((x, i) => (x, i)))
        {
            var cx      = p.Position.X.ToString("F1", CultureInfo.InvariantCulture);
            var cy      = p.Position.Y.ToString("F1", CultureInfo.InvariantCulture);
            var labelY  = (p.Position.Y + 36).ToString("F1", CultureInfo.InvariantCulture);
            var label   = HttpUtility.HtmlEncode(p.ShirtNumber ?? p.Position.Role);
            var name    = HttpUtility.HtmlEncode(ShortName(p.Name));
            var delay   = (idx * 0.07).ToString("F2", CultureInfo.InvariantCulture);
            var player  = p;
            <g style="animation: fadeInPlayer 0.35s ease both; animation-delay: @(delay)s; opacity: 0; cursor: pointer;"
               @onclick="() => _selected = player">
                @((MarkupString)$"<circle cx=\"{cx}\" cy=\"{cy}\" r=\"22\" fill=\"{homeFill}\" stroke=\"white\" stroke-width=\"2.5\" opacity=\"{homeOpacity}\"/>")
                @((MarkupString)$"<text x=\"{cx}\" y=\"{cy}\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"11\" fill=\"white\" font-family=\"Arial,sans-serif\" font-weight=\"bold\" opacity=\"{homeOpacity}\">{label}</text>")
                @((MarkupString)$"<text x=\"{cx}\" y=\"{labelY}\" text-anchor=\"middle\" font-size=\"18\" fill=\"white\" font-family=\"Arial,sans-serif\" font-weight=\"bold\" stroke=\"#2d7a3a\" stroke-width=\"3\" paint-order=\"stroke\" opacity=\"{homeOpacity}\">{name}</text>")
            </g>
        }

        <!-- Away players -->
        @{
            var awayFocused = FocusedSide is null || FocusedSide == TeamSide.Away;
            var awayOpacity = awayFocused ? "1" : "0.35";
            var awayFill    = awayFocused ? "#c0392b" : "#555";
        }
        @foreach (var (p, idx) in AwayPlayers.Select((x, i) => (x, i)))
        {
            var cx      = p.Position.X.ToString("F1", CultureInfo.InvariantCulture);
            var cy      = p.Position.Y.ToString("F1", CultureInfo.InvariantCulture);
            var labelY  = (p.Position.Y - 36).ToString("F1", CultureInfo.InvariantCulture);
            var label   = HttpUtility.HtmlEncode(p.ShirtNumber ?? p.Position.Role);
            var name    = HttpUtility.HtmlEncode(ShortName(p.Name));
            var delay   = ((HomePlayers.Count + idx) * 0.07).ToString("F2", CultureInfo.InvariantCulture);
            var player  = p;
            <g style="animation: fadeInPlayer 0.35s ease both; animation-delay: @(delay)s; opacity: 0; cursor: pointer;"
               @onclick="() => _selected = player">
                @((MarkupString)$"<circle cx=\"{cx}\" cy=\"{cy}\" r=\"22\" fill=\"{awayFill}\" stroke=\"white\" stroke-width=\"2.5\" opacity=\"{awayOpacity}\"/>")
                @((MarkupString)$"<text x=\"{cx}\" y=\"{cy}\" text-anchor=\"middle\" dominant-baseline=\"central\" font-size=\"11\" fill=\"white\" font-family=\"Arial,sans-serif\" font-weight=\"bold\" opacity=\"{awayOpacity}\">{label}</text>")
                @((MarkupString)$"<text x=\"{cx}\" y=\"{labelY}\" text-anchor=\"middle\" font-size=\"18\" fill=\"white\" font-family=\"Arial,sans-serif\" font-weight=\"bold\" stroke=\"#2d7a3a\" stroke-width=\"3\" paint-order=\"stroke\" opacity=\"{awayOpacity}\">{name}</text>")
            </g>
        }

    </svg>
</div>

@if (_selected is not null)
{
    <div class="player-popover-backdrop" @onclick="() => _selected = null">
        <div class="player-popover" @onclick:stopPropagation>
            <button class="popover-close" @onclick="() => _selected = null">✕</button>
            <div class="popover-name">@_selected.Name</div>
            <div class="popover-rows">
                <div class="popover-row">
                    <span class="popover-label">No.</span>
                    <span>@(_selected.ShirtNumber ?? "—")</span>
                </div>
                <div class="popover-row">
                    <span class="popover-label">Club</span>
                    <span>@(_selected.Club ?? "—")</span>
                </div>
                <div class="popover-row">
                    <span class="popover-label">Caps</span>
                    <span>@(_selected.Caps?.ToString() ?? "—")</span>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public IReadOnlyList<PlayerOnPitch> HomePlayers { get; set; } = [];
    [Parameter] public IReadOnlyList<PlayerOnPitch> AwayPlayers { get; set; } = [];
    [Parameter] public string HomeFormation { get; set; } = "";
    [Parameter] public string AwayFormation { get; set; } = "";
    [Parameter] public TeamSide? FocusedSide { get; set; }

    private PlayerOnPitch? _selected;

    private string RenderFormationLabels()
    {
        var sb = new System.Text.StringBuilder();
        if (!string.IsNullOrEmpty(HomeFormation))
            sb.Append($"<text x=\"340\" y=\"510\" text-anchor=\"middle\" font-size=\"18\" fill=\"white\" opacity=\"0.7\" font-family=\"Arial, sans-serif\">{HomeFormation}</text>");
        if (!string.IsNullOrEmpty(AwayFormation))
            sb.Append($"<text x=\"340\" y=\"545\" text-anchor=\"middle\" font-size=\"18\" fill=\"white\" opacity=\"0.7\" font-family=\"Arial, sans-serif\">{AwayFormation}</text>");
        return sb.ToString();
    }

    private static string ShortName(string name)
    {
        var parts = name.Split(' ');
        return parts.Length == 1 ? name : parts[^1];
    }
}

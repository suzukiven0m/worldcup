@page "/famous"
@rendermode InteractiveServer
@using WorldCupFormations.Data.Entities
@using WorldCupFormations.Data.Repositories
@inject IWorldCupRepository Repo

<PageTitle>Famous Formations — World Cup Formations</PageTitle>

<nav class="breadcrumb">
    <a href="/">World Cups</a> › <span>Famous Formations</span>
</nav>

<div class="page-header">
    <h2>Famous Formations</h2>
    <p>Historically significant line-ups — click to view the formation.</p>
</div>

@if (_loading)
{
    <p>Loading…</p>
}
else
{
    <div class="famous-list">
        @foreach (var f in _resolved)
        {
            @if (f.HomeTeamId.HasValue)
            {
                <div class="famous-card-wrap">
                    <a class="famous-card" href="/formation/@f.HomeTeamId.Value.matchId/@f.HomeTeamId.Value.teamId">
                        <div class="famous-formation-badge">@f.Formation</div>
                        <div class="famous-body">
                            <div class="famous-title">@f.Title</div>
                            <div class="famous-desc">@f.Description</div>
                        </div>
                        <div class="famous-arrow">›</div>
                    </a>
                </div>
            }
            else
            {
                <div class="famous-card famous-card-unavailable">
                    <div class="famous-formation-badge">@f.Formation</div>
                    <div class="famous-body">
                        <div class="famous-title">@f.Title</div>
                        <div class="famous-desc">@f.Description</div>
                        <div class="famous-na">Data not yet available</div>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<ResolvedEntry> _resolved = [];

    private static readonly FamousEntry[] _entries =
    [
        new(1930, "URU", "Uruguay 1930 — The First World Champions",
            "The 2-3-5 pyramid that won the inaugural World Cup, in front of 93 000 in Montevideo.",
            "2-3-5"),

        new(1958, "BRA", "Brazil 1958 — A Star Is Born",
            "The 17-year-old Pelé announced himself to the world with two goals in the final against Sweden.",
            "4-2-4"),

        new(1970, "BRA", "Brazil 1970 — The Beautiful Game's Zenith",
            "Pelé, Tostão, Jairzinho, Rivelino. Widely considered the greatest World Cup side ever assembled.",
            "4-3-3"),

        new(1974, "NED", "Netherlands 1974 — Total Football",
            "Cruyff's Netherlands revolutionised football with positional fluidity and high pressing.",
            "4-3-3"),

        new(1986, "ARG", "Argentina 1986 — Maradona's Masterclass",
            "The tournament where Diego Maradona single-handedly carried Argentina to glory in Mexico.",
            "3-5-2"),

        new(1998, "FRA", "France 1998 — Home Victory",
            "Zidane's brace in the final, Deschamps as captain. France's first World Cup on home soil.",
            "4-3-2-1"),

        new(2010, "ESP", "Spain 2010 — Tiki-Taka Supreme",
            "Del Bosque's Spain completed the treble: Euro 2008, World Cup 2010, Euro 2012 with the same core.",
            "4-2-3-1"),

        new(2014, "GER", "Germany 2014 — The 7-1 Machine",
            "The side that humiliated Brazil 7-1 in the semi-final went on to win with a Götze extra-time goal.",
            "4-3-2-1"),
    ];

    protected override async Task OnInitializedAsync()
    {
        _resolved = [];
        foreach (var e in _entries)
        {
            var match = await Repo.FindFinalAsync(e.Year);
            (int matchId, int teamId)? ids = null;

            if (match is not null)
            {
                // Pick the correct team side by code
                var teamId = match.HomeTeam.Code == e.TeamCode ? match.HomeTeamId
                           : match.AwayTeam.Code == e.TeamCode ? match.AwayTeamId
                           : (int?)null;
                if (teamId.HasValue)
                    ids = (match.Id, teamId.Value);
            }

            _resolved.Add(new ResolvedEntry(e, ids));
        }
        _loading = false;
    }

    private record FamousEntry(int Year, string TeamCode, string Title, string Description, string Formation);
    private record ResolvedEntry(FamousEntry Entry, (int matchId, int teamId)? HomeTeamId)
    {
        public string Title       => Entry.Title;
        public string Description => Entry.Description;
        public string Formation   => Entry.Formation;
    }
}

@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <a href="/" class="app-title">⚽ World Cup Formations</a>
        <nav class="header-nav">
            <a class="header-nav-link" href="/famous">Famous</a>
            <form class="header-search" action="/search" method="get">
                <input class="header-search-input" name="q" type="search" placeholder="Search players…" />
                <button class="header-search-btn" type="submit">›</button>
            </form>
        </nav>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
